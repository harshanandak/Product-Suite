{
  "framework": "nextjs",
  "installCommand": "bun install",
  "buildCommand": "bun run build",
  "ignoreCommand": "bash -c 'cd ../.. && git diff --quiet HEAD^ HEAD -- apps/roadmap-web packages infra/supabase package.json bun.lock'",
  "functions": {
    "app/api/ai/**/*.ts": {
      "maxDuration": 300,
      "memory": 1024
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
