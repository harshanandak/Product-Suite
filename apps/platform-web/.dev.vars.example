# ── E2E moat-loop run vars ────────────────────────────────────────────────────
# Copy this to `.env.e2e` (the CANONICAL file Playwright loads first) and fill in.
# `.dev.vars` is also loaded as a fallback if you keep local secrets there.
# The real values are NOT in the repo; both files are gitignored — never commit
# filled-in secrets.

# ── Clerk (auth) ──────────────────────────────────────────────────────────────
# Backend key: @clerk/testing uses this to mint a Testing Token for sign-in.
CLERK_SECRET_KEY=sk_test_xxx
# Publishable key the WEB app boots with (env.ts → CLERK_PUBLISHABLE_KEY).
# Must belong to the SAME Clerk instance as CLERK_SECRET_KEY above.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxx
# The Clerk test-mode user the E2E signs in as. NO password is needed:
# global.setup.e2e.ts calls `clerk.signIn({ emailAddress })`, which mints a
# short-lived Backend-API sign-in token and signs in with strategy "ticket".
# (If you ever switch to an email-code flow instead, Clerk test mode accepts the
# fixed verification code `424242` for any `+clerk_test` address / test user, so
# no real inbox is required — see https://clerk.com/docs/testing/test-emails-and-phones.)
E2E_CLERK_USER=e2e-tester@example.com

# ── Target selection ──────────────────────────────────────────────────────────
# LOCAL mode: leave E2E_BASE_URL UNSET — Playwright starts `bun run dev` on :5173.
# DEPLOYED mode: set to the live URL to run the same specs against a deploy
# (webServer is then skipped). Example:
# E2E_BASE_URL=https://platform-web.example.workers.dev
# Workspace slug in the URL (/w/<workspace>/…); defaults to befach-hq.
E2E_WORKSPACE=befach-hq
VITE_DEFAULT_WORKSPACE=befach-hq

# ── Backend secrets — required by the platform-API side for the loop to run ───
# In LOCAL mode these go to `wrangler dev` (the API worker on :8787 that the Vite
# proxy forwards /api/* to). In DEPLOYED mode they're already set on the deploy.
DATABASE_URL=postgres://user:pass@host/db   # Neon
OPENROUTER_API_KEY=sk-or-xxx                 # agent LLM calls
