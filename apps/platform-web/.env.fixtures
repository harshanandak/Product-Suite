# DEV-ONLY fixtures / preview mode. Loaded by `bun run dev:fixtures`
# (`vite --mode fixtures`). Serves in-memory fixture data and bypasses the Clerk
# auth gate so the Workboard + review inbox are viewable with NO backend and NO
# Clerk key. Has NO effect in a production build: `import.meta.env.DEV` is
# compile-time `false` there, so the guard folds away (see src/fixtures-mode.ts).
VITE_USE_FIXTURES=true
