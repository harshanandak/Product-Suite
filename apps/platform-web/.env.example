# Clerk GA React SDK — publishable key (client-safe, pk_test_… / pk_live_…).
# Get it from the Clerk Dashboard (https://dashboard.clerk.com) → API Keys.
# Without it the app boots to a setup notice; with it, sign-in works end-to-end.
VITE_CLERK_PUBLISHABLE_KEY=

# Default workspace slug used for the post-sign-in redirect (/w/<slug>).
VITE_DEFAULT_WORKSPACE=befach-hq

# DEV-ONLY fixtures/preview toggle. Prefer `bun run dev:fixtures` (loads
# .env.fixtures) over setting this by hand. When "true" AND running the dev
# server, the app serves in-memory fixture data and bypasses the Clerk auth gate
# so the Workboard + review inbox render with no backend. NO effect in a
# production build — the guard is compile-time `false` there (src/fixtures-mode.ts).
# VITE_USE_FIXTURES=true
